# ─── ANUBIX API Client — service secrets ────────────────────────────────────
# Copy this file to `.env` (which is .gitignored) and fill in real values.
# Never commit `.env`. Never paste these values into chat tools, screenshots,
# or pull requests.
#
# Sharing this file with others:
#   - This `.env.example` is the ONLY file safe to share — it contains no
#     real secrets, just keys + comments.
#   - Recipients fill in their own values from your team's secrets manager
#     (1Password / Doppler / Vault / AWS Secrets Manager / GCP Secret Manager).
#   - For local dev they save it as `.env` next to docker-compose.yml.
#   - For production: prefer Docker secrets, Kubernetes secrets, or your
#     cloud's secret manager — feed those into the container via env vars,
#     not by baking `.env` into the image.

# ─── Required ───────────────────────────────────────────────────────────────

# OmniLink API key (https://www.omnilink-agents.com → API & Keys).
OMNI_KEY=olink_REPLACE_ME

# SSH credentials to reach the Jetson over tailscale (or LAN).
# JETSON_IP defaults to the tailnet address of the Jetson if unset.
JETSON_IP=100.99.83.67
JETSON_USER=anubix
JETSON_PASS=REPLACE_ME
JETSON_SSH_PORT=22

# ─── Optional — Supabase ────────────────────────────────────────────────────
# If you want the service to fall back to a default upload destination when
# the caller omits per-request creds. Per-request user_id/task_id/chat_id
# still override these for the row contents.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=sb_publishable_REPLACE_ME

# ─── Optional — Tailscale ───────────────────────────────────────────────────
# A reusable-or-ephemeral pre-auth key from
# https://login.tailscale.com/admin/settings/keys
# If set, the container joins the tailnet at startup non-interactively.
# If unset, the daemon still starts but you must POST /tailscale/up to
# trigger interactive auth and open the returned login URL in a browser.
TAILSCALE_AUTHKEY=
TAILSCALE_HOSTNAME=anubix-api-client

# ─── Optional — server tuning ───────────────────────────────────────────────
PORT=6000
LOG_LEVEL=info
